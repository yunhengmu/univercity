# ===========================================
# 环境变量配置示例文件
# 请复制此文件为 .env 并填入真实的配置值
# ===========================================

# 数据库配置
DB_PASSWORD=your_database_password

# Redis 配置
REDIS_PASSWORD=your_redis_password

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# 阿里云 OSS 配置
ALIYUN_KEY_ID=your_aliyun_access_key_id
ALIYUN_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_BUCKET_NAME=your_bucket_name

# 微信配置
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret

# 微信支付配置
WEIXIN_APPID=your_weixin_appid
WEIXIN_PARTNER=your_weixin_partner
WEIXIN_PARTNERKEY=your_weixin_partnerkey
WEIXIN_NOTIFYURL=your_weixin_notify_url
WEIXIN_CERT_PATH=your_weixin_cert_path

# Elasticsearch 配置
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
