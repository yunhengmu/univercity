# ============================================
# Git 忽略文件配置
# ============================================

# 环境变量文件（包含真实密钥）
.env
.env.local
.env.production
.env.development
*.env

# 配置文件（包含敏感信息）
**/application-druid.yml
**/application-prod.yml
**/application-dev.yml

# 前端环境配置
graph_fontend/.env.local
graph_fontend/.env.production
ruoyi-ui/.env.local
ruoyi-ui/.env.production
ruoyi-admin/ruoyi-ui/.env.local
ruoyi-admin/ruoyi-ui/.env.production

# IDE 配置
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 编译输出
target/
build/
dist/
node_modules/
unpackage/

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
.DS_Store
Thumbs.db

# 上传文件目录
D:/uploadOne
D:/ruoyi/uploadPath
uploadPath/

# Nginx 配置（如果包含敏感信息）
nginx/conf/

# 其他
*.swp
*.swo
*~
